/* css/ai.css */
.chat-container { display: flex; flex-direction: column; height: 62vh; background: var(--surface-color); border-radius: 20px; border: 1px solid var(--glass-border); overflow: hidden; }
.messages-box { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
.msg { max-width: 75%; padding: 12px 16px; border-radius: 16px; font-size: 15px; line-height: 1.4; }
.msg.user { background: var(--primary-color); align-self: flex-end; border-bottom-right-radius: 4px; }
.msg.ai { background: #334155; align-self: flex-start; border-bottom-left-radius: 4px; }
.chat-input-area { display: flex; padding: 12px; background: rgba(15,23,42,0.8); gap: 10px; border-top: 1px solid var(--glass-border); }
#ai-input { flex: 1; background: rgba(30,41,59,0.5); border: 1px solid var(--glass-border); padding: 12px 18px; border-radius: 25px; color: white; outline: none; }
